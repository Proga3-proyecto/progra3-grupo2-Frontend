@page "/login"
<div class="container">
    <section>
        <div class="form-header">
            <i class="bi bi-person-lock logo"></i>
            <h1 class="title">
                INICIO DE SESIÓN
            </h1>
            <h3 class="sub-title">
                Introduzca su correo electrónico y contraseña:
            </h3>
            <div class="hr" />
        </div>
        <form>

            <div class="form-input">
                <label for="email">Correo electrónico</label>
                <div class="input-container">
                    <i class="bi bi-envelope"></i>
                    <input id="email" placeholder="ejemplo@correo.com" type="email" />
                </div>
            </div>

            <div class="form-input">
                <label for="password">Contraseña</label>
                <div class="input-container">
                    <i class="bi bi-lock-fill"></i>
                    <input id="password" type="@(hidePassword ? "password":"text" )" placeholder="*************" />
                    <div @onclick="changeVisibility">
                        @if (hidePassword)
                        {
                            <i class="bi bi-eye-slash"></i>
                        }
                        else
                        {
                            <i class="bi bi-eye"></i>
                        }
                    </div>
                </div>
            </div>
            <a class="link">¿Olvidaste tu contraseña?</a>

            <button type="submit">Ingresar</button>
        </form>
        <div>
            <span class="label">¿Eres nuevo?</span>
            <a class="link">Crear un cuenta</a>
        </div>
    </section>
</div>


@code {
    bool hidePassword = false;
    void changeVisibility()
    {
        hidePassword = !hidePassword;
    }
}
