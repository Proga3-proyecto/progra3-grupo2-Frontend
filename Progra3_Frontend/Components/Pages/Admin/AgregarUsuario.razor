@page "/AgregarUsuario"
@using System.ComponentModel.DataAnnotations

<style>
    .text-navy { color: #021947; }
    .navy-bg { background-color: #021947; color: white; transition: background-color 0.2s; }
    .navy-bg:hover { background-color: #010d26; color: white; }
    
    .form-container { 
        background: white; 
        border-radius: 12px; 
        border: 1px solid #f1f5f9; 
        padding: 40px; 
        max-width: 900px;
        margin: 0 auto;
    }

    .form-label-custom { font-weight: 600; color: #1e293b; font-size: 0.9rem; margin-bottom: 6px; }
    
    .custom-input { 
        border-radius: 8px; background-color: #ffffff; border: 1px solid #cbd5e1; 
        font-size: 0.95rem; padding-top: 10px; padding-bottom: 10px; color: #334155;
    }
    .custom-input:focus { box-shadow: 0 0 0 3px rgba(2, 25, 71, 0.1); border-color: #021947; }
    .custom-input::placeholder { color: #94a3b8; }

    .icon-left { top: 12px; left: 14px; color: #64748b; font-size: 1.1rem; }
    .icon-right { top: 12px; right: 14px; color: #64748b; cursor: pointer; font-size: 1.1rem; }
    
    .validation-text { color: #dc3545; font-size: 0.85rem; margin-top: 4px; display: block; font-weight: 500;}
</style>


<div class="container-fluid mt-5 mb-5">
    
    <div class="text-center mb-4">
        <h2 class="fw-bold text-navy" style="letter-spacing: 1px;">AGREGAR USUARIO</h2>
        <p class="text-muted">Completa los datos para registrar un nuevo usuario en el sistema.</p>
    </div>

    <div class="form-container shadow-sm">
        
        <EditForm Model="NewUser" OnValidSubmit="GuardarUsuario">
            
            <DataAnnotationsValidator />

            <div class="row gx-5">
                
                <div class="col-md-6">
                    
                    <div class="mb-4">
                        <label class="form-label form-label-custom">Nombre(s)</label>
                        <div class="position-relative">
                            <i class="bi bi-person position-absolute icon-left"></i>
                            <input type="text" class="form-control custom-input ps-5" placeholder="Ingresa tu nombre(s)" @bind="NewUser.Nombre">
                        </div>
                        <ValidationMessage For="@(() => NewUser.Nombre)" class="validation-text" />
                    </div>

                    <div class="row mb-4">
                        <div class="col-6">
                            <label class="form-label form-label-custom">Apellido Paterno</label>
                            <div class="position-relative">
                                <i class="bi bi-person position-absolute icon-left"></i>
                                <input type="text" class="form-control custom-input ps-5" placeholder="Ingresa tu apellido" @bind="NewUser.ApellidoPaterno">
                            </div>
                            <ValidationMessage For="@(() => NewUser.ApellidoPaterno)" class="validation-text" />
                        </div>
                        <div class="col-6">
                            <label class="form-label form-label-custom">Apellido Materno</label>
                            <div class="position-relative">
                                <i class="bi bi-person position-absolute icon-left"></i>
                                <input type="text" class="form-control custom-input ps-5" placeholder="Ingresa tu apellido" @bind="NewUser.ApellidoMaterno">
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label form-label-custom">Correo electrónico</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute icon-left"></i>
                            <input type="email" class="form-control custom-input ps-5" placeholder="ejemplo@correo.com" @bind="NewUser.Correo">
                        </div>
                        <ValidationMessage For="@(() => NewUser.Correo)" class="validation-text" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label form-label-custom">Contraseña</label>
                        <div class="position-relative">
                            <i class="bi bi-lock position-absolute icon-left"></i>
                            <input type="@(ShowPassword ? "text" : "password")" class="form-control custom-input ps-5 pe-5" placeholder="Crea una contraseña" @bind="NewUser.Contrasena">
                            <i class="bi @(ShowPassword ? "bi-eye" : "bi-eye-slash") position-absolute icon-right" @onclick="TogglePasswordVisibility"></i>
                        </div>
                        <ValidationMessage For="@(() => NewUser.Contrasena)" class="validation-text" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label form-label-custom">Repetir Contraseña</label>
                        <div class="position-relative">
                            <i class="bi bi-lock position-absolute icon-left"></i>
                            <input type="@(ShowRepeatPassword ? "text" : "password")" class="form-control custom-input ps-5 pe-5" placeholder="Repite tu contraseña" @bind="NewUser.RepetirContrasena">
                            <i class="bi @(ShowRepeatPassword ? "bi-eye" : "bi-eye-slash") position-absolute icon-right" @onclick="ToggleRepeatPasswordVisibility"></i>
                        </div>
                        <ValidationMessage For="@(() => NewUser.RepetirContrasena)" class="validation-text" />
                    </div>

                </div>

                <div class="col-md-6">
                    
                    <div class="mb-4">
                        <label class="form-label form-label-custom">DNI</label>
                        <div class="position-relative">
                            <i class="bi bi-person-vcard position-absolute icon-left"></i>
                            <input type="text" class="form-control custom-input ps-5" placeholder="Ingresa tu DNI" maxlength="8" @bind="NewUser.Dni">
                        </div>
                        <ValidationMessage For="@(() => NewUser.Dni)" class="validation-text" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label form-label-custom">Fecha de Nacimiento</label>
                        <div class="position-relative">
                            <input type="date" class="form-control custom-input text-muted" @bind="NewUser.FechaNacimiento">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label form-label-custom">Rol de Usuario</label>
                        <div class="position-relative">
                            <i class="bi bi-shield-check position-absolute icon-left"></i>
                            <select class="form-select custom-input ps-5" @bind="NewUser.Rol">
                                <option value="" disabled selected>Selecciona un rol</option>
                                <option value="Cliente">Cliente</option>
                                <option value="Administrador">Administrador</option>
                            </select>
                        </div>
                    </div>

                </div>
            </div>
            
            <div class="text-center mt-5 mb-2">
                <button type="submit" class="btn navy-bg px-5 py-2" style="border-radius: 8px; font-weight: 500; font-size: 1.05rem;">
                    Crear cuenta
                </button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    public class UsuarioFormDto
    {
        [Required(ErrorMessage = "El nombre es obligatorio")]
        public string Nombre { get; set; } = string.Empty;

        [Required(ErrorMessage = "El apellido es obligatorio")]
        public string ApellidoPaterno { get; set; } = string.Empty;
        
        public string ApellidoMaterno { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio")]
        [EmailAddress(ErrorMessage = "Formato de correo inválido (ej. usuario@gmail.com)")]
        public string Correo { get; set; } = string.Empty;

        [Required(ErrorMessage = "Crea una contraseña")]
        public string Contrasena { get; set; } = string.Empty;

        [Required(ErrorMessage = "Repite la contraseña")]
        [Compare(nameof(Contrasena), ErrorMessage = "La contraseña no es la misma")]
        public string RepetirContrasena { get; set; } = string.Empty;

        [Required(ErrorMessage = "El DNI es obligatorio")]
        [StringLength(8, MinimumLength = 8, ErrorMessage = "El DNI debe tener 8 dígitos")]
        public string Dni { get; set; } = string.Empty;

        public DateTime? FechaNacimiento { get; set; }
        public string Rol { get; set; } = "Cliente";
    }
    private UsuarioFormDto NewUser { get; set; } = new();

    private bool ShowPassword { get; set; } = false;
    private bool ShowRepeatPassword { get; set; } = false;
    private void TogglePasswordVisibility() => ShowPassword = !ShowPassword;
    private void ToggleRepeatPasswordVisibility() => ShowRepeatPassword = !ShowRepeatPassword;

    private void GuardarUsuario()
    {
        /* Luego, se añadirá lógica para guardar el usuario en la BD (transformar UsuarioFormDto -> UsuarioDTO y llamar al método guardarUsuario) */
        Console.WriteLine($"Guardando en BD: {NewUser.Correo}");
    }
}