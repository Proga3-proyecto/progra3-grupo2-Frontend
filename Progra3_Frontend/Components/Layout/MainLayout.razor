@inherits LayoutComponentBase
<div class="layout">
    <div>
        <div class="header-contact">
            <div class="contact-item">
                <i class="bi bi-envelope contact-icon"></i>
                <span>CONSULTASCLIENTES@LICORERIA.ALLASI.COM</span>
            </div>
            <span>|</span>
            <div class="contact-item">
                <i class="bi bi-telephone contact-icon "></i>
                <span>(01) 123-4567</span>
            </div>
            <span>|</span>
            <div class="contact-item">
                <i class="bi bi-geo-alt contact-icon"></i>
                <span>AV.UNIVERSITARIA 1801, SAN MIGUEL, LIMA</span>
            </div>
        </div>

        <div class="header">
            <img src="./assets/logo.png" class="logo" />
            <div class="search-container">
                <i class="bi bi-search"></i>
                <input class="search" placeholder="Buscar productos, recetas, marcas..." />
            </div>
            <div class="controls">
                <i class="bi bi-person-circle user-icon"></i>
                <div class="shopping-chart-container">
                    <i class="bi bi-cart shopping-chart"></i>
                    <di class="shopping-chart-value">0</di>
                </div>
            </div>

        </div>
        <nav class="nav">
            <a href="/">Inicio</a>
            <a>RON</a>
            <a>VODKA</a>
            <a>WHISKY</a>
            <a>GIN</a>
            <a>PISCO</a>
            <a>VINO</a>
            <a>LICORES</a>
            <a>RECETAS</a>
            <a>PACKS</a>
            <a>OFERTAS</a>
        </nav>
    </div>
    @Body;
</div>

