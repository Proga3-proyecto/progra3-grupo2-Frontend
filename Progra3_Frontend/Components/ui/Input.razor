<div class="form-group-container">
    <label class="form-input-label">@Label</label>

    <div class="custom-input-group">

        @if (Password)
        {
            <span class="input-icon-prefix">
                <img src="assets/icons/candadoURL.png" alt="Candado" class="field-icon-img" />
            </span>
        }

        @if (TextArea)
        {
            <textarea class="custom-form-control text-input"
                      placeholder="@PlaceHolder"
                          @attributes="AdditionalAttributes">
            </textarea>
            }
        else
            {
                <input type="@type"
                       class="custom-form-control text-input"
                       placeholder="@PlaceHolder"
                       @attributes="AdditionalAttributes" />
            }

            @if (Password && !TextArea)
            {
                <button class="input-icon-suffix" type="button" @onclick="onHide">
                    <img src="@(hide ? "assets/icons/OjoCerrado.png" : "assets/icons/OjoAbierto.png")"
                         alt="Mostrar"
                         class="field-icon-img" />
                </button>
            }

        </div>
    </div>

@code {
    [Parameter]
    public bool Password { get; set; } = false;

    [Parameter]
    public bool TextArea { get; set; } = false;

    [Parameter]
    public string? PlaceHolder { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs>? OnInput { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool hide = true;
    private string type => Password && hide ? "password" : "text";

    private void onHide()
    {
        hide = !hide;
    }
}