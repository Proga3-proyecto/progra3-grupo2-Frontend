@page "/user"
@using Progra3_Frontend.Components.Shared.ui
@layout UserLayout

<h1 class="titulo">Mi perfil</h1>

<p class="subtitulo">
    Administra tu información personal y de contacto.
</p>

<h3>Información personal</h3>

<div class="grid">
    <Input Label="Nombre completo" value="Juan Carlos Pérez Rodriguez" disabled />
    <Input Label="DNI" value="12345678" disabled />
    <Input Label="Fecha de nacimiento" value="1988-05-15" disabled type="date" />
    <Input Label="Fecha de creación de cuenta" value="2023-03-20" disabled type="date" />
</div>

<hr />

<h3>Información de contacto</h3>

<div class="grid">
    <Input Label="Número de teléfono" value="912 345 678" type="text"  />
    <Input Label="Dirección de entrega"
           value="Av. Universitaria 1801, San Miguel, Lima, Perú"
           type="text"
           TextArea
           rows="2" />
</div>

<div class="boton-container">
    <Button Text="Guardar cambios" Class="primary"/>
</div>

<p class="security-footer-text">
    <img src="assets/icons/escudo.png" alt="Seguro" class="footer-shield-icon-img" /> Tu información está segura con nosotros y no será compartida con terceros.
</p>
