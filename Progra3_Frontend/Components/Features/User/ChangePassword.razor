@page "/user/change-password"
@using Progra3_Frontend.Components.Shared.ui
@layout UserLayout

<div class="password-page-container">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-navy mb-1" style="font-size: 1.35rem;">Cambiar mi contraseña</h2>
        <p class="text-muted mb-2" style="font-size: 0.85rem;">Por tu seguridad, elige una contraseña segura que no uses en otros sitios.</p>
    </div>

    <div class="password-form-card">
        <EditForm Model="@passwordModel" OnValidSubmit="HandleSubmit">

            <div class="mb-3">
                <Input password="true"
                       label="Contraseña actual"
                       @bind-value="passwordModel.CurrentPassword" />
            </div>

            <div class="mb-3">
                <Input Password="true"
                       Label="Nueva contraseña"
                       @bind-Value="passwordModel.NewPassword"></Input>
                 
            </div>

            <div class="mb-3">
                <IndicatorBar Color="@strengthColor" State="@strengthText" Percent="@strengthPercent" Label="Seguridad" />
            </div>

            <div class="mb-3">
                <Input password="true"
                       label="Repetir nueva contraseña"
                       @bind-value="passwordModel.ConfirmPassword" />
            </div>

            <div class="requirements-box mt-2 mb-3">
                <p class="requirements-title">
                    <img src="assets/icons/infromacion.png" alt="Info" class="info-icon-img" /> Tu contraseña debe contener:
                </p>
                <div class="row g-2">
                    <div class="col-sm-6 requirement-item">
                        <img src="@(hasMinLength ? "assets/icons/checkVerde.png" : "assets/icons/equisRoja.png")" alt="Check" class="check-icon-img" /> Mínimo 8 caracteres
                    </div>
                    <div class="col-sm-6 requirement-item">
                        <img src="@(hasNumber ? "assets/icons/checkVerde.png" : "assets/icons/equisRoja.png")" alt="Check" class="check-icon-img" /> Al menos un número
                    </div>
                    <div class="col-sm-6 requirement-item">
                        <img src="@(hasUpper ? "assets/icons/checkVerde.png" : "assets/icons/equisRoja.png")" alt="Check" class="check-icon-img" /> Al menos una letra mayúscula
                    </div>
                    <div class="col-sm-6 requirement-item">
                        <img src="@(hasSpecial ? "assets/icons/checkVerde.png" : "assets/icons/equisRoja.png")" alt="Check" class="check-icon-img" /> Al menos un carácter especial
                    </div>
                </div>
            </div>

            <div class="submit-container pt-3 mt-4" style="border-top: 1px solid rgba(170,170,170,0.3);">
                <Button Text="Actualizar contraseña" type="submit" Class="navy-bg w-100 py-2" style="border-radius: 6px; font-weight: 500; font-size: 0.85rem;" />
            </div>

        </EditForm>
    </div>

    <p class="security-footer-text">
        <img src="assets/icons/escudo.png" alt="Seguro" class="footer-shield-icon-img" /> Tu información está segura con nosotros y no será compartida con terceros.
    </p>
</div>

@code {
    private PasswordClass passwordModel = new PasswordClass();

    // Tus validaciones actuales (¡están perfectas!)
    private bool hasMinLength => (passwordModel.NewPassword?.Length >= 8);
    private bool hasNumber => !string.IsNullOrEmpty(passwordModel.NewPassword) && passwordModel.NewPassword.Any(char.IsDigit);
    private bool hasUpper => !string.IsNullOrEmpty(passwordModel.NewPassword) && passwordModel.NewPassword.Any(char.IsUpper);
    private bool hasSpecial => !string.IsNullOrEmpty(passwordModel.NewPassword) && passwordModel.NewPassword.Any(c => !char.IsLetterOrDigit(c));

    // 1. Calculamos el puntaje dinámicamente
    private int PasswordScore
    {
        get
        {
            if (string.IsNullOrEmpty(passwordModel.NewPassword)) return 0;
            int score = 0;
            if (hasMinLength) score++;
            if (hasNumber) score++;
            if (hasUpper) score++;
            if (hasSpecial) score++;
            return score;
        }
    }

    // 2. Propiedades reactivas para la barra de seguridad
    private string strengthText => PasswordScore switch
    {
        4 => "Fuerte",
        3 => "Media",
        2 => "Media",
        _ => "Débil"
    };

    private string strengthColor => PasswordScore switch
    {
        4 => "#198754", // Verde
        3 => "#ffc107", // Amarillo
        2 => "#ffc107", // Amarillo
        _ => "#dc3545"  // Rojo
    };

    private int strengthPercent => PasswordScore switch
    {
        4 => 100,
        3 => 75,
        2 => 50,
        1 => 25,
        _ => 15
    };

    private void HandleSubmit()
    {
        if (passwordModel.NewPassword == passwordModel.ConfirmPassword && strengthPercent == 100)
        {
            // Simulación frontend de guardado exitoso
        }
    }

    public class PasswordClass
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}