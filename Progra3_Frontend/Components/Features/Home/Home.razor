@page "/"

<section class="home-page">

    <section class="hero-section">

        <img src="/assets/inicio.png" class="hero-img" />

        <div class="hero-overlay">

            <button class="hero-arrow hero-arrow-left">
                <i class="bi bi-chevron-left"></i>
            </button>

            <div class="hero-text">
                <h1>
                    LOS MEJORES LICORES,<br />
                    PARA LOS MEJORES MOMENTOS
                </h1>

                <p>
                    Descubre nuestra selección de licores premium<br />
                    y encuentra tu favorito
                </p>

                <button class="hero-button">
                    Ver productos
                </button>
            </div>

            <button class="hero-arrow hero-arrow-right">
                <i class="bi bi-chevron-right"></i>
            </button>

            <div class="hero-dots">
                <span class="active"></span>
                <span></span>
                <span></span>
            </div>

        </div>

    </section>

    <section class="best-sellers-section">

        <h2>LO MÁS VENDIDO</h2>

        <div class="best-sellers-grid">

            <article class="best-card">

                <div class="rank-badge">1</div>

                <div class="best-img-box">
                    <img src="/assets/products/vino/vino-casillero.png" class="best-img" />
                </div>

                <div class="best-info">
                    <h3>Casillero del Diablo</h3>
                    <p>Vino</p>

                    <div class="best-bottom">
                        <span>S/ 49.00</span>

                        <button class="best-cart-button">
                            <i class="bi bi-cart"></i>
                        </button>
                    </div>
                </div>

            </article>

            <article class="best-card">

                <div class="rank-badge">2</div>

                <div class="best-img-box">
                    <img src="/assets/products/whisky/whisky-johnnie-walker.png" class="best-img" />
                </div>

                <div class="best-info">
                    <h3>Johnnie Walker<br />Red Label</h3>
                    <p>Whisky</p>

                    <div class="best-bottom">
                        <span>S/ 75.00</span>

                        <button class="best-cart-button">
                            <i class="bi bi-cart"></i>
                        </button>
                    </div>
                </div>

            </article>

            <article class="best-card">

                <div class="rank-badge">3</div>

                <div class="best-img-box">
                    <img src="/assets/products/gin/gin-tanqueray.png" class="best-img" />
                </div>

                <div class="best-info">
                    <h3>Tanqueray<br />London Dry Gin</h3>
                    <p>Gin</p>

                    <div class="best-bottom">
                        <span>S/ 89.00</span>

                        <button class="best-cart-button">
                            <i class="bi bi-cart"></i>
                        </button>
                    </div>
                </div>

            </article>

            <article class="best-card">

                <div class="rank-badge">4</div>

                <div class="best-img-box">
                    <img src="/assets/products/vodka/vodka-absolut.png" class="best-img" />
                </div>

                <div class="best-info">
                    <h3>Absolut Vodka</h3>
                    <p>Vodka</p>

                    <div class="best-bottom">
                        <span>S/ 65.00</span>

                        <button class="best-cart-button">
                            <i class="bi bi-cart"></i>
                        </button>
                    </div>
                </div>

            </article>

        </div>

    </section>

    <section class="benefits-section">

        <div class="benefit-item">
            <div class="benefit-icon">
                <i class="bi bi-shield-check"></i>
            </div>

            <div>
                <h3>Compra 100% segura</h3>
                <p>Protegemos tus datos</p>
            </div>
        </div>

        <div class="benefit-separator"></div>

        <div class="benefit-item">
            <div class="benefit-icon">
                <i class="bi bi-truck"></i>
            </div>

            <div>
                <h3>Envíos a todo el Perú</h3>
                <p>Rápidos y confiables</p>
            </div>
        </div>

        <div class="benefit-separator"></div>

        <div class="benefit-item">
            <div class="benefit-icon">
                <i class="bi bi-patch-check-fill"></i>
            </div>

            <div>
                <h3>Productos originales</h3>
                <p>Garantía de calidad</p>
            </div>
        </div>

        <div class="benefit-separator"></div>

        <div class="benefit-item">
            <div class="benefit-icon">
                <i class="bi bi-percent"></i>
            </div>

            <div>
                <h3>Ofertas exclusivas</h3>
                <p>Descuentos especiales</p>
            </div>
        </div>

    </section>

</section>