
@page "/category/{CategoriaRoute}"
@using Progra3_Frontend.Components.Features.Products.components

<div class="products-banner">
    <img src="@BannerImage" class="products-banner-img" />
    <div class="products-banner-content">
        <h1 class="products-title">@Titulo</h1>
        <div class="products-divider">
            <span></span>
            <i class="fa-light fa-martini-glass"></i>
            <span></span>
        </div>
        <p class="products-description">@Descripcion</p>
    </div>
</div>

<section class="products-section">
    <div class="filter-container">
        <ProductsFilter />
    </div>
    <main class="products-area">

        <div class="products-top">
            <p>Mostrando @ProductosPaginados.Count de @ProductosFiltrados.Count producto(s)</p>
        </div>

        <div class="products-grid">
            @* Iteramos sobre ProductosPaginados en lugar de ProductosFiltrados *@
            @foreach (var producto in ProductosPaginados)
            {
                <ProductCard Producto="producto" />
            }
        </div>

        @* Controles de paginación *@
        @if (TotalPages > 1)
        {
            <div class="pagination-container">
                <button class="btn-page" disabled="@(currentPage == 1)" @onclick="PaginaAnterior">Anterior</button>

                @for (int i = 1; i <= TotalPages; i++)
                {
                    var numeroPagina = i;
                    <button class="btn-page @(currentPage == numeroPagina ? "active" : "")" @onclick="() => IrAPagina(numeroPagina)">
                        @numeroPagina
                    </button>
                }

                <button class="btn-page" disabled="@(currentPage == TotalPages)" @onclick="PaginaSiguiente">Siguiente</button>
            </div>
        }

    </main>
</section>

@code {
    [Parameter]
    public string? CategoriaRoute { get; set; }

    private decimal? precioMin;
    private decimal? precioMax;

    private string Titulo = "TODOS LOS PRODUCTOS";
    private string Descripcion = "Descubre nuestra selección premium";
    private string BannerImage = "/assets/banner/banner.png";

    // --- VARIABLES DE PAGINACIÓN ---
    private int currentPage = 1;
    private int pageSize = 15; // Mostrar 30 productos por página

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(CategoriaRoute))
        {
            Titulo = "TODOS LOS PRODUCTOS";
        }
        else
        {
            Titulo = CategoriaRoute.ToUpper();
        }

        // Reiniciar a la primera página al cambiar de categoría
        currentPage = 1;
        LimpiarFiltros();
    }

    private List<Producto> Productos = new()
    {
        // --- GIN ---
        new() { Nombre = "Beefeater London Dry Gin", Categoria = "Gin", Precio = 69, Imagen = "gin-beefeater.png" },
        new() { Nombre = "Bombay Sapphire", Categoria = "Gin", Precio = 85, Imagen = "gin-bombay.png" },
        new() { Nombre = "Tanqueray London Dry", Categoria = "Gin", Precio = 89, Imagen = "gin-tanqueray.png" },
        new() { Nombre = "Hendrick's Gin", Categoria = "Gin", Precio = 149, Imagen = "gin-hendricks.png" },

        // --- LICORES ---
        new() { Nombre = "Jägermeister", Categoria = "Licor", Precio = 79, Imagen = "licor-jagermeister.png" },
        new() { Nombre = "Baileys Original", Categoria = "Licor", Precio = 69, Imagen = "licor-baileys.png" },
        new() { Nombre = "Kahlúa", Categoria = "Licor", Precio = 65, Imagen = "licor-kahlua.png" },
        new() { Nombre = "Amaretto Disaronno", Categoria = "Licor", Precio = 89, Imagen = "licor-amaretto.png" },

        // --- PISCO ---
        new() { Nombre = "Pisco Portón Mosto Verde", Categoria = "Pisco", Precio = 89, Imagen = "pisco-porton.png" },
        new() { Nombre = "Pisco Quebranta", Categoria = "Pisco", Precio = 49, Imagen = "pisco-quebranta.png" },
        new() { Nombre = "Pisco Acholado", Categoria = "Pisco", Precio = 59, Imagen = "pisco-acholado.png" },
        new() { Nombre = "Pisco Tabernero Italia", Categoria = "Pisco", Precio = 52, Imagen = "pisco-tabernero.png" },

        // --- RON ---
        new() { Nombre = "Bacardí Carta Blanca", Categoria = "Ron", Precio = 49, Imagen = "ron-bacardi.png" },
        new() { Nombre = "Cartavio Selecto", Categoria = "Ron", Precio = 42, Imagen = "ron-cartavio.png" },
        new() { Nombre = "Havana Club Añejo", Categoria = "Ron", Precio = 58, Imagen = "ron-havana-club.png" },
        new() { Nombre = "Ron Zacapa 23", Categoria = "Ron", Precio = 189, Imagen = "ron-zacapa.png" },

        // --- VINO ---
        new() { Nombre = "Casillero del Diablo", Categoria = "Vino", Precio = 49, Imagen = "vino-casillero.png" },
        new() { Nombre = "Navarro Correas", Categoria = "Vino", Precio = 59, Imagen = "vino-navarro-correas.png" },
        new() { Nombre = "Trapiche Malbec", Categoria = "Vino", Precio = 45, Imagen = "vino-trapiche.png" },
        new() { Nombre = "Marqués de Riscal", Categoria = "Vino", Precio = 89, Imagen = "vino-marques.png" },

        // --- VODKA ---
        new() { Nombre = "Absolut Vodka", Categoria = "Vodka", Precio = 65, Imagen = "vodka-absolut.png" },
        new() { Nombre = "Smirnoff Red", Categoria = "Vodka", Precio = 55, Imagen = "vodka-smirnoff.png" },
        new() { Nombre = "Grey Goose", Categoria = "Vodka", Precio = 119, Imagen = "vodka-grey-goose.png" },
        new() { Nombre = "Stolichnaya", Categoria = "Vodka", Precio = 59, Imagen = "vodka-stolichnaya.png" },

        // --- WHISKY ---
        new() { Nombre = "Johnnie Walker Red Label", Categoria = "Whisky", Precio = 69, Imagen = "whisky-johnnie-walker.png" },
        new() { Nombre = "Jack Daniel's", Categoria = "Whisky", Precio = 89, Imagen = "whisky-jack-daniels.png" },
        new() { Nombre = "Chivas Regal 12 años", Categoria = "Whisky", Precio = 129, Imagen = "whisky-chivas-regal.png" },
        new() { Nombre = "Johnnie Walker Black Label", Categoria = "Whisky", Precio = 149, Imagen = "whisky-black-label.png" }
    };

    private List<Producto> ProductosFiltrados =>
        Productos.Where(p =>
            (string.IsNullOrWhiteSpace(CategoriaRoute) || p.Categoria.Equals(CategoriaRoute, StringComparison.OrdinalIgnoreCase)) &&
            (!precioMin.HasValue || p.Precio >= precioMin) &&
            (!precioMax.HasValue || p.Precio <= precioMax))
        .ToList();

    // --- PROPIEDADES CALCULADAS PARA PAGINACIÓN ---
    private int TotalPages => (int)Math.Ceiling(ProductosFiltrados.Count / (double)pageSize);

    private List<Producto> ProductosPaginados =>
        ProductosFiltrados
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

    // --- MÉTODOS DE PAGINACIÓN ---
    private void IrAPagina(int page)
    {
        currentPage = page;
    }

    private void PaginaAnterior()
    {
        if (currentPage > 1) currentPage--;
    }

    private void PaginaSiguiente()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void LimpiarFiltros()
    {
        precioMin = null;
        precioMax = null;
        currentPage = 1; // Volver a la primera página al limpiar filtros
    }
}