@page "/admin"
@page "/admin/product-list"
@layout AdminLayout

<div class="container-fluid mt-3" style="max-width: 1400px;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-navy mb-0 main-title">Control de Stock de Productos</h2>
        <button class="btn navy-bg d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg" style="font-size: 0.8rem;"></i> Añadir Nuevo Producto
        </button>
    </div>

    <div class="mb-3">
        <div class="input-container" style="max-width: 400px; background-color: white;">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Buscar por nombre, SKU..." />
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table class="table custom-table table-borderless align-middle w-100">
                <thead class="text-start">
                    <tr>
                        <th scope="col" style="width: 45%;" class="text-start px-2">PRODUCTO</th>
                        <th scope="col" class="text-center">SKU</th>
                        <th scope="col" class="text-center">STOCK ACTUAL</th>
                        <th scope="col" class="text-center">STOCK MÍNIMO</th>
                        <th scope="col" class="text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody class="text-start">
                    @foreach (var product in GetPagedProducts())
                    {
                        <tr>
                            <td class="px-2">
                                <div class="d-flex align-items-center">
                                    <div class="product-img-container flex-shrink-0">
                                        @* <img src="@product.ImageUrl" alt="@product.Name" class="product-img" /> *@
                                    </div>
                                    <span class="fw-bold text-navy product-name">@product.Name</span>
                                </div>
                            </td>

                            <td class="text-center text-muted text-nowrap product-sku">
                                @product.Sku
                            </td>

                            <td class="text-center text-nowrap">
                                <span class="fw-bold text-dark stock-current">@product.CurrentStock</span>
                            </td>

                            <td class="text-center text-nowrap">
                                <span class="fw-bold text-navy stock-min">@product.MinStock</span>
                            </td>

                            <td class="text-center text-nowrap">
                                <button class="btn btn-outline-custom btn-sm">
                                    Actualizar Stock
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-3 mb-1">
                <nav>
                    <ul class="pagination custom-pagination pagination-sm">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="GoToPreviousPage" disabled="@(CurrentPage == 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>

                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(CurrentPage == pageNumber ? "active" : "")">
                                <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                            </li>
                        }

                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="GoToNextPage" disabled="@(CurrentPage == TotalPages)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
@code {
    /* Clase DTO temporal */
    public class ProductDto
    {
        public string Sku { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public int CurrentStock { get; set; }
        public int MinStock { get; set; }
    }

    private List<ProductDto> Products { get; set; } = new();

    // Variables de paginación
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 4;
    private int TotalPages => (int)Math.Ceiling((double)Products.Count / PageSize);

    private IEnumerable<ProductDto> GetPagedProducts()
    {
        return Products.Skip((CurrentPage - 1) * PageSize).Take(PageSize);
    }

    private void ChangePage(int page) => CurrentPage = page;
    private void GoToPreviousPage() { if (CurrentPage > 1) CurrentPage--; }
    private void GoToNextPage() { if (CurrentPage < TotalPages) CurrentPage++; }

    /* Inicializacion de pagina */
    protected override void OnInitialized()
    {
        // Data de prueba
        Products.Add(new ProductDto
        {
            Name = "CHIVAS REGAL 12 AÑOS",
            Sku = "CHIV-12A",
            CurrentStock = 15,
            MinStock = 5,
            ImageUrl = ""
        });
        Products.Add(new ProductDto
        {
            Name = "CATENA ZAPATA MALBEC",
            Sku = "CAT-MAL",
            CurrentStock = 8,
            MinStock = 3,
            ImageUrl = ""
        });
        Products.Add(new ProductDto
        {
            Name = "CUATRO GALLOS PISCO QUEBRANTA",
            Sku = "PIS-QUE",
            CurrentStock = 20,
            MinStock = 6,
            ImageUrl = ""
        });
        Products.Add(new ProductDto
        {
            Name = "FLOR DE CAÑA 7 AÑOS",
            Sku = "RON-7A",
            CurrentStock = 12,
            MinStock = 4,
            ImageUrl = ""
        });
    }
}