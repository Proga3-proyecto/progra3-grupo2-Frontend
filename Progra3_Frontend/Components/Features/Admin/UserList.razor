@page "/admin/user-list"
@layout AdminLayout

<div class="container-fluid mt-3" style="max-width: 1400px;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-navy mb-0" style="font-size: 1.35rem;">Lista de usuarios</h2>
        <button class="btn navy-bg d-flex align-items-center gap-2" style="border-radius: 6px; font-weight: 500; font-size: 0.82rem; padding: 6px 14px;">
            <i class="bi bi-plus-lg"></i> Nuevo usuario
        </button>
    </div>

    <div class="table-container shadow-sm">

        <div class="mb-3">
            <div class="input-container" style="max-width: 400px; background-color: white;">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Buscar usuario..." />
            </div>
        </div>

        <div class="mb-3 d-flex gap-2">
            <button class="btn btn-sm fw-medium @(SelectedFilter == "Todos" ? "navy-bg" : "btn-filter-inactive")"
                    style="border-radius: 6px; padding: 4px 12px; font-size: 0.8rem;"
                    @onclick='() => FilterByRole("Todos")'>
                Todos
            </button>
            <button class="btn btn-sm fw-medium @(SelectedFilter == "Administrador" ? "navy-bg" : "btn-filter-inactive")"
                    style="border-radius: 6px; padding: 4px 12px; font-size: 0.8rem;"
                    @onclick='() => FilterByRole("Administrador")'>
                Administradores
            </button>
            <button class="btn btn-sm fw-medium @(SelectedFilter == "Cliente" ? "navy-bg" : "btn-filter-inactive")"
                    style="border-radius: 6px; padding: 4px 12px; font-size: 0.8rem;"
                    @onclick='() => FilterByRole("Cliente")'>
                Clientes
            </button>
        </div>

        <div class="table-responsive">
            <table class="table custom-table table-borderless align-middle w-100">
                <thead>
                    <tr>
                        <th scope="col" style="width: 35%;" class="ps-2">USUARIO</th>
                        <th scope="col">ROL</th>
                        <th scope="col">FECHA DE REGISTRO</th>
                        <th scope="col">ÚLTIMA ACTIVIDAD</th>
                        <th scope="col">ESTADO</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!GetPagedUsers().Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No se encontraron usuarios con este filtro.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in GetPagedUsers())
                        {
                            <tr>
                                <td class="ps-2">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2 flex-shrink-0">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark" style="font-size: 0.85rem; line-height: 1.2;">@user.Name</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@user.Email</div>
                                            <span class="badge-id">ID: @user.Id</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-dark fw-medium" style="font-size: 0.82rem;">@user.Role</td>
                                <td>
                                    <div class="text-dark fw-medium" style="font-size: 0.82rem;">@user.RegistrationDate.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@user.RegistrationDate.ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    <div class="text-dark fw-medium" style="font-size: 0.82rem;">@user.LastActivityDateText</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@user.LastActivityTimeText</div>
                                </td>
                                <td>
                                    <span class="fw-bold @(user.IsActive ? "text-success" : "text-danger")" style="font-size: 0.82rem;">
                                        @(user.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-3 mb-1">
                <nav>
                    <ul class="pagination custom-pagination pagination-sm">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="GoToPreviousPage" disabled="@(CurrentPage == 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>

                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(CurrentPage == pageNumber ? "active" : "")">
                                <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                            </li>
                        }

                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="GoToNextPage" disabled="@(CurrentPage == TotalPages)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }

    </div>
</div>

@code {
    /* Clase DTO temporal */
    public class UserDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public DateTime RegistrationDate { get; set; }
        public string LastActivityDateText { get; set; } = string.Empty;
        public string LastActivityTimeText { get; set; } = string.Empty;
        public bool IsActive { get; set; }
    }

    private List<UserDto> Users { get; set; } = new();
    private string SelectedFilter { get; set; } = "Todos";
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 8;

    private IEnumerable<UserDto> FilteredUsers =>
        SelectedFilter == "Todos" ? Users : Users.Where(u => u.Role == SelectedFilter);

    private int TotalPages => (int)Math.Ceiling((double)FilteredUsers.Count() / PageSize);

    private IEnumerable<UserDto> GetPagedUsers()
    {
        return FilteredUsers.Skip((CurrentPage - 1) * PageSize).Take(PageSize);
    }

    private void FilterByRole(string role)
    {
        SelectedFilter = role;
        CurrentPage = 1;
    }

    private void ChangePage(int page) => CurrentPage = page;
    private void GoToPreviousPage() { if (CurrentPage > 1) CurrentPage--; }
    private void GoToNextPage() { if (CurrentPage < TotalPages) CurrentPage++; }

    protected override void OnInitialized()
    {
