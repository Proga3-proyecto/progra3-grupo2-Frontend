@page "/admin/add-user"
@layout AdminLayout
@using System.ComponentModel.DataAnnotations

<div class="container-fluid mt-3 mb-4">

    <div class="text-center mb-3">
        <h2 class="fw-bold text-navy" style="letter-spacing: 0.5px; font-size: 1.35rem;">AGREGAR USUARIO</h2>
        <p class="text-muted" style="font-size: 0.85rem;">Completa los datos para registrar un nuevo usuario en el sistema.</p>
    </div>

    <div class="form-container">

        <EditForm Model="NewUser" OnValidSubmit="GuardarUsuario">
            <DataAnnotationsValidator />

            <div class="row gx-4">
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label-custom">Nombre(s) <span class="asterisk">*</span></label>
                        <div class="input-container">
                            <i class="bi bi-person"></i>
                            <input type="text" placeholder="Ingresa tu nombre(s)" @bind="NewUser.Nombre">
                        </div>
                        <ValidationMessage For="@(() => NewUser.Nombre)" class="validation-text" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label-custom">Apellido Paterno <span class="asterisk">*</span></label>
                            <div class="input-container">
                                <i class="bi bi-person"></i>
                                <input type="text" placeholder="Ingresa tu apellido" @bind="NewUser.ApellidoPaterno">
                            </div>
                            <ValidationMessage For="@(() => NewUser.ApellidoPaterno)" class="validation-text" />
                        </div>
                        <div class="col-6">
                            <label class="form-label-custom">Apellido Materno</label>
                            <div class="input-container">
                                <i class="bi bi-person"></i>
                                <input type="text" placeholder="Ingresa tu apellido" @bind="NewUser.ApellidoMaterno">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Correo electrónico <span class="asterisk">*</span></label>
                        <div class="input-container">
                            <i class="bi bi-envelope"></i>
                            <input type="email" placeholder="ejemplo@correo.com" @bind="NewUser.Correo">
                        </div>
                        <ValidationMessage For="@(() => NewUser.Correo)" class="validation-text" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Contraseña <span class="asterisk">*</span></label>
                        <div class="input-container">
                            <i class="bi bi-lock"></i>
                            <input type="@(ShowPassword ? "text" : "password")" placeholder="Crea una contraseña" @bind="NewUser.Contrasena">
                            <i class="bi @(ShowPassword ? "bi-eye" : "bi-eye-slash")" @onclick="TogglePasswordVisibility" style="cursor: pointer;"></i>
                        </div>
                        <ValidationMessage For="@(() => NewUser.Contrasena)" class="validation-text" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Repetir Contraseña <span class="asterisk">*</span></label>
                        <div class="input-container">
                            <i class="bi bi-lock"></i>
                            <input type="@(ShowRepeatPassword ? "text" : "password")" placeholder="Repite tu contraseña" @bind="NewUser.RepetirContrasena">
                            <i class="bi @(ShowRepeatPassword ? "bi-eye" : "bi-eye-slash")" @onclick="ToggleRepeatPasswordVisibility" style="cursor: pointer;"></i>
                        </div>
                        <ValidationMessage For="@(() => NewUser.RepetirContrasena)" class="validation-text" />
                    </div>

                </div>

                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label-custom">DNI <span class="asterisk">*</span></label>
                        <div class="input-container">
                            <i class="bi bi-person-vcard"></i>
                            <input type="text" placeholder="Ingresa tu DNI" maxlength="8" @bind="NewUser.Dni">
                        </div>
                        <ValidationMessage For="@(() => NewUser.Dni)" class="validation-text" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Fecha de Nacimiento</label>
                        <div class="input-container">
                            <i class="bi bi-calendar3"></i>
                            <input type="date" @bind="NewUser.FechaNacimiento" style="color: inherit;">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Rol de Usuario <span class="asterisk">*</span></label>
                        <div class="input-container">
                            <i class="bi bi-shield-check"></i>
                            <select @bind="NewUser.Rol">
                                <option value="" disabled selected>Selecciona un rol</option>
                                <option value="Cliente">Cliente</option>
                                <option value="Administrador">Administrador</option>
                            </select>
                        </div>
                    </div>

                </div>
            </div>

            <div class="text-center mt-3 pt-3 mb-1" style="border-top: 1px solid rgba(170,170,170,0.3);">
                <button type="submit" class="btn navy-bg" style="border-radius: 6px; font-weight: 500; font-size: 0.82rem; padding: 6px 14px;">
                    Crear cuenta
                </button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    public class UsuarioFormDto
    {
        [Required(ErrorMessage = "El nombre es obligatorio")]
        public string Nombre { get; set; } = string.Empty;

        [Required(ErrorMessage = "El apellido es obligatorio")]
        public string ApellidoPaterno { get; set; } = string.Empty;

        public string ApellidoMaterno { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio")]
        [EmailAddress(ErrorMessage = "Formato de correo inválido")]
        public string Correo { get; set; } = string.Empty;

        [Required(ErrorMessage = "Crea una contraseña")]
        public string Contrasena { get; set; } = string.Empty;

        [Required(ErrorMessage = "Repite la contraseña")]
        [Compare(nameof(Contrasena), ErrorMessage = "La contraseña no coincide")]
        public string RepetirContrasena { get; set; } = string.Empty;

        [Required(ErrorMessage = "El DNI es obligatorio")]
        [StringLength(8, MinimumLength = 8, ErrorMessage = "El DNI debe tener 8 dígitos")]
        public string Dni { get; set; } = string.Empty;

        public DateTime? FechaNacimiento { get; set; }
        public string Rol { get; set; } = "Cliente";
    }

    private UsuarioFormDto NewUser { get; set; } = new();
    private bool ShowPassword { get; set; } = false;
    private bool ShowRepeatPassword { get; set; } = false;

    private void TogglePasswordVisibility() => ShowPassword = !ShowPassword;
    private void ToggleRepeatPasswordVisibility() => ShowRepeatPassword = !ShowRepeatPassword;

    private void GuardarUsuario()
    {
        Console.WriteLine($"Guardando en BD: {NewUser.Correo}");
    }
}