@page "/admin/order-details"
@layout AdminLayout

<div class="container-fluid mt-3" style="max-width: 1400px;">

    <div class="mb-4">
        <a href="/admin/order-list" class="back-link mb-3 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> Volver a pedidos
        </a>
        <h2 class="fw-bold text-navy mb-0 main-title">Detalles del Pedido #@Order.Id</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem;">Panel de Administración</p>
    </div>

    <div class="details-container shadow-sm">
        
        <div class="row gx-5 mb-5">
            
            <div class="col-md-4 info-column">
                <h6 class="fw-bold text-navy mb-4" style="font-size: 1.05rem;">Información del Cliente</h6>
                
                <div class="d-flex mb-3">
                    <i class="bi bi-person info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Nombre:</div>
                        <div class="info-value">@Order.ClientName</div>
                    </div>
                </div>
                
                <div class="d-flex mb-3">
                    <i class="bi bi-envelope info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Correo:</div>
                        <div class="info-value">@Order.ClientEmail</div>
                    </div>
                </div>
                
                <div class="d-flex mb-3">
                    <i class="bi bi-telephone info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Teléfono:</div>
                        <div class="info-value">@Order.ClientPhone</div>
                    </div>
                </div>
                
                <div class="d-flex">
                    <i class="bi bi-geo-alt info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Dirección de Envío:</div>
                        <div class="info-value">@Order.ShippingAddress</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 info-column">
                <h6 class="fw-bold text-navy mb-4" style="font-size: 1.05rem;">Información del Pedido</h6>
                
                <div class="d-flex mb-3">
                    <i class="bi bi-file-earmark-text info-icon mt-1"></i>
                    <div>
                        <div class="info-label">ID Pedido:</div>
                        <div class="info-value">@Order.Id</div>
                    </div>
                </div>
                
                <div class="d-flex mb-3">
                    <i class="bi bi-arrow-left-right info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Estado:</div>
                        <div class="info-value">@Order.Status</div>
                    </div>
                </div>
                
                <div class="d-flex mb-3">
                    <i class="bi bi-credit-card info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Método de Pago:</div>
                        <div class="info-value">@Order.PaymentMethod</div>
                    </div>
                </div>
                
                <div class="d-flex">
                    <i class="bi bi-geo-alt info-icon mt-1"></i>
                    <div>
                        <div class="info-label">Dirección de Facturación:</div>
                        <div class="info-value">@Order.BillingAddress</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <h6 class="fw-bold text-navy mb-4" style="font-size: 1.05rem;">Resumen Financiero</h6>
                
                <div class="summary-row">
                    <span class="info-label text-muted">Subtotal:</span>
                    <span class="info-value">S/. @Order.Subtotal.ToString("F2")</span>
                </div>
                
                <div class="summary-row">
                    <span class="info-label text-muted">IGV (18%):</span>
                    <span class="info-value">S/. @Order.Tax.ToString("F2")</span>
                </div>
                
                <div class="summary-row">
                    <span class="info-label text-muted">Costo de Envío:</span>
                    <span class="info-value">S/. @Order.ShippingCost.ToString("F2")</span>
                </div>
                
                <div class="summary-row">
                    <span class="info-label text-muted">Descuentos:</span>
                    <span class="info-value">S/. @Order.Discount.ToString("F2")</span>
                </div>
                
                <div class="summary-row summary-total mt-4 pt-3">
                    <span>Total (S/.):</span>
                    <span class="fw-bold" style="font-size: 1.4rem;">S/. @Order.Total.ToString("F2")</span>
                </div>
            </div>

        </div>

        <div>
            <h6 class="fw-bold text-navy mb-3" style="font-size: 1.05rem;">Productos en este Pedido</h6>
            
            <div class="table-responsive">
                <table class="table custom-table table-borderless align-middle w-100 mb-0">
                    <thead class="text-start">
                        <tr>
                            <th scope="col" style="width: 10%;">ID Producto</th>
                            <th scope="col" class="text-center" style="width: 15%;">Imagen</th>
                            <th scope="col" style="width: 30%;">Nombre del Producto</th>
                            <th scope="col" class="text-center" style="width: 15%;">Categoría</th>
                            <th scope="col" class="text-center" style="width: 10%;">Cantidad</th>
                            <th scope="col" class="text-center" style="width: 10%;">Precio Unitario</th>
                            <th scope="col" class="text-center" style="width: 10%;">Total Línea</th>
                        </tr>
                    </thead>
                    <tbody class="text-start">
                        @foreach (var item in Order.Items)
                        {
                            <tr>
                                <td class="text-dark font-medium">@item.ProductId</td>
                                <td class="text-center">
                                    <div class="product-img-container mx-auto">
                                        <img src="@item.ImageUrl" alt="@item.ProductName" class="product-img" onerror="this.src='https://via.placeholder.com/40x60?text=Botella'" />
                                    </div>
                                </td>
                                <td class="text-dark fw-medium">@item.ProductName</td>
                                <td class="text-center text-muted">@item.Category</td>
                                <td class="text-center text-dark fw-bold">@item.Quantity</td>
                                <td class="text-center text-dark">S/. @item.UnitPrice.ToString("F2")</td>
                                <td class="text-center text-dark fw-medium">S/. @item.LineTotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@code {
    // Modelos DTO temporales
    public class OrderDetailDto
    {
        public string Id { get; set; } = string.Empty;
        public string ClientName { get; set; } = string.Empty;
        public string ClientEmail { get; set; } = string.Empty;
        public string ClientPhone { get; set; } = string.Empty;
        public string ShippingAddress { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string PaymentMethod { get; set; } = string.Empty;
        public string BillingAddress { get; set; } = string.Empty;
        public decimal Subtotal { get; set; }
        public decimal Tax { get; set; }
        public decimal ShippingCost { get; set; }
        public decimal Discount { get; set; }
        public decimal Total { get; set; }
        public List<OrderItemDto> Items { get; set; } = new();
    }

    public class OrderItemDto
    {
        public string ProductId { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal LineTotal => Quantity * UnitPrice;
    }

    private OrderDetailDto Order { get; set; } = new();

    protected override void OnInitialized()
    {
        // Data de prueba
        Order = new OrderDetailDto
        {
            Id = "0003",
            ClientName = "David Menez",
            ClientEmail = "david.menez@email.com",
            ClientPhone = "(98) 987-6543",
            ShippingAddress = "Jr. Ica 123, Int. 5, Lima",
            Status = "Enviado",
            PaymentMethod = "Yape",
            BillingAddress = "Jr. Ica 123, Int. 5, Lima",
            Subtotal = 57.00m,
            Tax = 8.70m,
            ShippingCost = 0.00m,
            Discount = 0.00m,
            Total = 57.00m,
            Items = new List<OrderItemDto>
            {
                new OrderItemDto
                {
                    ProductId = "151",
                    ImageUrl = "",
                    ProductName = "Whisky Jack Daniel's 750ml",
                    Category = "Whisky",
                    Quantity = 1,
                    UnitPrice = 57.00m
                }
            }
        };
    }
}